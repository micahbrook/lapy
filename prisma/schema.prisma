generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TradeType {
  ELECTRICIAN
  PLUMBER
  HVAC
  CARPENTER
  PAINTER
  BUILDER
  OTHER
}

enum AustralianState {
  NSW
  VIC
  QLD
  SA
  WA
  TAS
  NT
  ACT
}

enum JobStatus {
  ENQUIRY
  QUOTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  INVOICED
  PAID
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum SwmsStatus {
  DRAFT
  SIGNED
  ARCHIVED
}

enum SubscriptionPlan {
  SOLO
  CREW
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum NotificationType {
  QUOTE_ACCEPTED
  QUOTE_DECLINED
  JOB_SCHEDULED
  INVOICE_PAID
  INVOICE_OVERDUE
  PAYMENT_REMINDER
  TEAM_INVITE
  SYSTEM
}

model User {
  id             String          @id @default(cuid())
  clerkId        String          @unique
  email          String          @unique
  name           String
  phone          String?
  tradeType      TradeType?
  licenceNumber  String?
  state          AustralianState?
  abn            String?
  businessName   String?
  logoUrl        String?
  brandColour    String?         @default("#f97316")
  bankBsb        String?
  bankAccount    String?
  bankName       String?
  defaultPaymentTerms Int?       @default(14)
  defaultQuoteValidity Int?      @default(30)
  defaultNotes   String?
  invoiceFooter  String?
  onboardingComplete Boolean     @default(false)
  trialEndsAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  customers      Customer[]
  jobs           Job[]
  quotes         Quote[]
  invoices       Invoice[]
  swms           Swms[]
  parts          Part[]
  subscription   Subscription?
  notifications  Notification[]
  teamMemberships TeamMember[]   @relation("TeamOwner")
  memberOf       TeamMember[]   @relation("TeamMember")
  aiUsageLogs    AiUsageLog[]

  @@index([clerkId])
  @@index([email])
}

model Customer {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  address   String?
  suburb    String?
  state     AustralianState?
  postcode  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs   Job[]
  quotes Quote[]

  @@index([userId])
  @@index([userId, name])
}

model Job {
  id            String      @id @default(cuid())
  userId        String
  customerId    String?
  title         String
  description   String?
  status        JobStatus   @default(ENQUIRY)
  jobType       String?
  address       String?
  suburb        String?
  state         AustralianState?
  scheduledAt   DateTime?
  completedAt   DateTime?
  totalAmount   Decimal?    @db.Decimal(10, 2)
  notes         String?
  photos        String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id])
  quotes    Quote[]
  invoices  Invoice[]
  swms      Swms[]
  jobParts  JobPart[]
  timeline  JobTimeline[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, scheduledAt])
  @@index([customerId])
}

model Quote {
  id          String      @id @default(cuid())
  jobId       String?
  userId      String
  customerId  String?
  quoteNumber String      @unique
  lineItems   Json        @default("[]")
  subtotal    Decimal     @db.Decimal(10, 2) @default(0)
  gst         Decimal     @db.Decimal(10, 2) @default(0)
  total       Decimal     @db.Decimal(10, 2) @default(0)
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?
  sentAt      DateTime?
  acceptedAt  DateTime?
  pdfUrl      String?
  notes       String?
  publicToken String?     @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  job      Job?      @relation(fields: [jobId], references: [id])
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  invoices Invoice[]

  @@index([userId])
  @@index([userId, status])
  @@index([jobId])
  @@index([publicToken])
}

model Invoice {
  id                String        @id @default(cuid())
  jobId             String?
  quoteId           String?
  userId            String
  invoiceNumber     String        @unique
  lineItems         Json          @default("[]")
  subtotal          Decimal       @db.Decimal(10, 2) @default(0)
  gst               Decimal       @db.Decimal(10, 2) @default(0)
  total             Decimal       @db.Decimal(10, 2) @default(0)
  depositAmount     Decimal?      @db.Decimal(10, 2)
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime?
  paidAt            DateTime?
  paidReference     String?
  xeroInvoiceId     String?
  pdfUrl            String?
  notes             String?
  stripePaymentLink String?
  remindersSent     Json          @default("[]")
  publicToken       String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  job   Job?   @relation(fields: [jobId], references: [id])
  quote Quote? @relation(fields: [quoteId], references: [id])
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([jobId])
  @@index([xeroInvoiceId])
  @@index([publicToken])
}

model Swms {
  id                   String     @id @default(cuid())
  jobId                String?
  userId               String
  swmsNumber           String     @unique
  jobDescription       String?
  highRiskWork         Boolean    @default(false)
  highRiskCategories   String[]
  hazards              Json       @default("[]")
  controls             Json       @default("[]")
  ppe                  Json       @default("[]")
  scopeOfWork          String?
  emergencyProcedures  String?
  siteAddress          String?
  principalContractor  String?
  nearestHospital      String?
  emergencyContact     String?
  workers              Json       @default("[]")
  signatures           Json       @default("[]")
  status               SwmsStatus @default(DRAFT)
  isTemplate           Boolean    @default(false)
  templateName         String?
  signedAt             DateTime?
  pdfUrl               String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  job  Job?  @relation(fields: [jobId], references: [id])
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([jobId])
  @@index([userId, isTemplate])
}

model Part {
  id          String   @id @default(cuid())
  userId      String
  name        String
  sku         String?
  supplier    String?
  unitCost    Decimal  @db.Decimal(10, 2) @default(0)
  sellPrice   Decimal  @db.Decimal(10, 2) @default(0)
  unit        String?  @default("ea")
  stockLevel  Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobParts JobPart[]

  @@index([userId])
  @@index([userId, name])
}

model JobPart {
  id        String  @id @default(cuid())
  jobId     String
  partId    String?
  name      String
  quantity  Decimal @db.Decimal(10, 3) @default(1)
  unitCost  Decimal @db.Decimal(10, 2) @default(0)
  totalCost Decimal @db.Decimal(10, 2) @default(0)

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  part Part? @relation(fields: [partId], references: [id])

  @@index([jobId])
  @@index([partId])
}

model JobTimeline {
  id        String   @id @default(cuid())
  jobId     String
  event     String
  detail    String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(SOLO)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model TeamMember {
  id          String   @id @default(cuid())
  ownerId     String
  memberId    String
  role        String   @default("TECHNICIAN")
  inviteEmail String?
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now())

  owner  User @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  member User @relation("TeamMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([ownerId, memberId])
  @@index([ownerId])
  @@index([memberId])
}

model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  model     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, feature])
}

model XeroConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  tenantId     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}
